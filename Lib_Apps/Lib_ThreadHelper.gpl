''' <summary>
''' User Defined Module
''' </summary>
Module Lib_ThreadHelper

    'Thread State 
	' -1 (Never Started)
	' 0 (Completed Sucess)
	' 1 (Stopping)
	' 2 (Executing)
	' 3 (Paused)
	' 4 (Errored)
	Public Sub RestartThreadIfNeeded(td As Thread)
		Dim threadstate As Integer
		threadstate = td.ThreadState
		If threadstate <> 2 Then
			If (threadstate > 0) Then
				td.Abort
			End If
			thread.Sleep(2)
			td.Start
		End If
	End Sub

End Module
